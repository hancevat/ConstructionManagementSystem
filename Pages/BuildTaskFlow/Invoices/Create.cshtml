@page
@model ConstructionManagementSystem.Pages.BuildTaskFlow.Invoices.CreateModel
@{
    ViewData["Title"] = "Proforma/Fatura Taslağı Ekle";
}

<div class="page-heading">
    <h1 class="h3 mb-0">Yeni Proforma/Fatura Taslağı</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Listeye Dön</a>
</div>

<div class="alert alert-info">
    Bu ekran resmi fatura kesmez. Operasyon takibi için tarihli, numaralı ve kalemli taslak oluşturur.
</div>

<div class="content-card form-card p-4">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="row">
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.InvoiceNumber" class="form-label"></label>
                <input asp-for="Invoice.InvoiceNumber" class="form-control" />
                <span asp-validation-for="Invoice.InvoiceNumber" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.BuildTaskFlowProjectId" class="form-label"></label>
                <select asp-for="Invoice.BuildTaskFlowProjectId" asp-items="Model.ProjectOptions" class="form-select">
                    <option value="">Proje seçin</option>
                </select>
                <span asp-validation-for="Invoice.BuildTaskFlowProjectId" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.CustomerTitle" class="form-label"></label>
                <input asp-for="Invoice.CustomerTitle" class="form-control" />
                <span asp-validation-for="Invoice.CustomerTitle" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.InvoiceDate" class="form-label"></label>
                <input asp-for="Invoice.InvoiceDate" class="form-control" />
                <span asp-validation-for="Invoice.InvoiceDate" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.DueDate" class="form-label"></label>
                <input asp-for="Invoice.DueDate" class="form-control" />
                <span asp-validation-for="Invoice.DueDate" class="text-danger"></span>
            </div>
            <div class="col-md-4 mb-3">
                <label asp-for="Invoice.Status" class="form-label"></label>
                <select asp-for="Invoice.Status" class="form-select">
                    @foreach (var status in Model.StatusOptions)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
                <span asp-validation-for="Invoice.Status" class="text-danger"></span>
            </div>
        </div>

        <h2 class="h5 mt-3">Kalem</h2>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="InvoiceItem.Description" class="form-label"></label>
                <input asp-for="InvoiceItem.Description" class="form-control" />
                <span asp-validation-for="InvoiceItem.Description" class="text-danger"></span>
            </div>
            <div class="col-md-2 mb-3">
                <label asp-for="InvoiceItem.Quantity" class="form-label"></label>
                <input asp-for="InvoiceItem.Quantity" class="form-control" />
                <span asp-validation-for="InvoiceItem.Quantity" class="text-danger"></span>
            </div>
            <div class="col-md-2 mb-3">
                <label asp-for="InvoiceItem.UnitPrice" class="form-label"></label>
                <input asp-for="InvoiceItem.UnitPrice" class="form-control" />
                <span asp-validation-for="InvoiceItem.UnitPrice" class="text-danger"></span>
            </div>
            <div class="col-md-2 mb-3">
                <label asp-for="Invoice.TaxRate" class="form-label"></label>
                <input asp-for="Invoice.TaxRate" class="form-control" />
                <span asp-validation-for="Invoice.TaxRate" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Invoice.Notes" class="form-label"></label>
            <textarea asp-for="Invoice.Notes" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Invoice.Notes" class="text-danger"></span>
        </div>

        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Taslak Oluştur</button>
            <a class="btn btn-outline-secondary" asp-page="Index">Vazgeç</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
