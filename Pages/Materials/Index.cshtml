@page
@model ConstructionManagementSystem.Pages.Materials.IndexModel
@{
    ViewData["Title"] = "Malzemeler";
    var canManage = BuildTaskFlowPermissions.CanManageMaterials(User);
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Malzemeler</h1>
        <p class="text-muted mb-0">Şirkette takip edilen inşaat malzemeleri ve stok miktarları.</p>
    </div>
    @if (canManage)
    {
        <a class="btn btn-primary" asp-page="Create">Yeni Malzeme Ekle</a>
    }
</div>

<div class="content-card p-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Malzeme</th>
                    <th>Tür</th>
                    <th>Birim</th>
                    <th>Birim Fiyat</th>
                    <th>Stok</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Materials)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.MaterialType?.Name</td>
                        <td>@item.Unit</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@item.StockQuantity.ToString("N2") @item.Unit</td>
                        <td>
                            <div class="actions">
                                <a class="btn btn-outline-info btn-sm" asp-page="Details" asp-route-id="@item.Id">Detay</a>
                                @if (canManage)
                                {
                                    <a class="btn btn-outline-primary btn-sm" asp-page="Edit" asp-route-id="@item.Id">Düzenle</a>
                                    <a class="btn btn-outline-danger btn-sm" asp-page="Delete" asp-route-id="@item.Id">Sil</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

