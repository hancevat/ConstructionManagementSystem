@page
@model ConstructionManagementSystem.Pages.ConstructionProjects.IndexModel
@{
    ViewData["Title"] = "Projeler";
    var canManage = BuildTaskFlowPermissions.CanManageProjects(User);
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">Projeler</h1>
        <p class="text-muted mb-0">Şirketin yürüttüğü şantiye ve proje kayıtları.</p>
    </div>
    @if (canManage)
    {
        <a class="btn btn-primary" asp-page="Create">Yeni Proje Ekle</a>
    }
</div>

<div class="content-card p-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Proje</th>
                    <th>Müşteri</th>
                    <th>Lokasyon</th>
                    <th>Durum</th>
                    <th>Sözleşme Bedeli</th>
                    <th>Başlangıç</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.ConstructionProjects)
                {
                    <tr>
                        <td>@item.Name</td>
                        <td>@item.Client?.CompanyName</td>
                        <td>@item.Location</td>
                        <td><span class="badge @(item.Status == "Aktif" ? "text-bg-primary" : "text-bg-success")">@item.Status</span></td>
                        <td>@item.ContractAmount.ToString("C")</td>
                        <td>@item.StartDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="actions">
                                <a class="btn btn-outline-info btn-sm" asp-page="Details" asp-route-id="@item.Id">Detay</a>
                                @if (canManage)
                                {
                                    <a class="btn btn-outline-primary btn-sm" asp-page="Edit" asp-route-id="@item.Id">Düzenle</a>
                                    <a class="btn btn-outline-danger btn-sm" asp-page="Delete" asp-route-id="@item.Id">Sil</a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

