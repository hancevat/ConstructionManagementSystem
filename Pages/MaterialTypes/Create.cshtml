@page
@model ConstructionManagementSystem.Pages.MaterialTypes.CreateModel
@{
    ViewData["Title"] = "Yeni Malzeme Türü Ekle";
}

<div class="page-heading">
    <h1 class="h3 mb-0">Yeni Malzeme Türü Ekle</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Listeye Dön</a>
</div>

<div class="content-card form-card p-4">
    <form method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="mb-3">
            <label asp-for="MaterialType.Name" class="form-label"></label>
            <input asp-for="MaterialType.Name" class="form-control" />
            <span asp-validation-for="MaterialType.Name" class="text-danger"></span>
        </div>
        <div class="mt-4 d-flex gap-2">
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a class="btn btn-outline-secondary" asp-page="Index">Vazgeç</a>
        </div>
    </form>
</div>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}


