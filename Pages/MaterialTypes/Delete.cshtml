@page "{id:int}"
@model ConstructionManagementSystem.Pages.MaterialTypes.DeleteModel
@{
    ViewData["Title"] = "Malzeme Türü Sil";
}

<div class="page-heading">
    <h1 class="h3 mb-0">Malzeme Türü Sil</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Listeye Dön</a>
</div>

<div class="content-card form-card p-4">
    <div class="alert alert-warning">
        <strong>@Model.MaterialType.Name</strong> malzeme türünü silmek istediğinizden emin misiniz?
    </div>
    <form method="post">
        <input type="hidden" asp-for="MaterialType.Id" />
        <button type="submit" class="btn btn-danger">Sil</button>
        <a class="btn btn-outline-secondary" asp-page="Index">Vazgeç</a>
    </form>
</div>

