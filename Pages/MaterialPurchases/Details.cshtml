@page "{id:int}"
@model ConstructionManagementSystem.Pages.MaterialPurchases.DetailsModel
@{
    ViewData["Title"] = "Malzeme Alımı Detayı";
}

<div class="page-heading">
    <h1 class="h3 mb-0">Malzeme Alımı Detayı</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Listeye Dön</a>
</div>

<div class="content-card p-4">
    <div class="details-grid">
        <div class="details-item"><div class="details-label">Proje</div><div class="details-value">@Model.MaterialPurchase.ConstructionProject?.Name</div></div>
        <div class="details-item"><div class="details-label">Malzeme</div><div class="details-value">@Model.MaterialPurchase.Material?.Name</div></div>
        <div class="details-item"><div class="details-label">Tedarikçi</div><div class="details-value">@Model.MaterialPurchase.Supplier?.CompanyName</div></div>
        <div class="details-item"><div class="details-label">Tarih</div><div class="details-value">@Model.MaterialPurchase.PurchaseDate.ToString("dd.MM.yyyy")</div></div>
        <div class="details-item"><div class="details-label">Miktar</div><div class="details-value">@Model.MaterialPurchase.Quantity.ToString("N2") @Model.MaterialPurchase.Material?.Unit</div></div>
        <div class="details-item"><div class="details-label">Birim Fiyat</div><div class="details-value">@Model.MaterialPurchase.UnitPrice.ToString("C")</div></div>
        <div class="details-item"><div class="details-label">Toplam Tutar</div><div class="details-value">@Model.MaterialPurchase.TotalAmount.ToString("C")</div></div>
        <div class="details-item"><div class="details-label">Açıklama</div><div class="details-value">@Model.MaterialPurchase.Description</div></div>
    </div>
</div>

