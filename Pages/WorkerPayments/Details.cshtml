@page "{id:int}"
@model ConstructionManagementSystem.Pages.WorkerPayments.DetailsModel
@{
    ViewData["Title"] = "İşçi Ödemesi Detayı";
}

<div class="page-heading">
    <h1 class="h3 mb-0">İşçi Ödemesi Detayı</h1>
    <a class="btn btn-outline-secondary" asp-page="Index">Listeye Dön</a>
</div>

<div class="content-card p-4">
    <div class="details-grid">
        <div class="details-item"><div class="details-label">İşçi</div><div class="details-value">@Model.WorkerPayment.Worker?.FullName</div></div>
        <div class="details-item"><div class="details-label">Proje</div><div class="details-value">@Model.WorkerPayment.ConstructionProject?.Name</div></div>
        <div class="details-item"><div class="details-label">Tarih</div><div class="details-value">@Model.WorkerPayment.PaymentDate.ToString("dd.MM.yyyy")</div></div>
        <div class="details-item"><div class="details-label">Çalışılan Gün</div><div class="details-value">@Model.WorkerPayment.WorkDays</div></div>
        <div class="details-item"><div class="details-label">Tutar</div><div class="details-value">@Model.WorkerPayment.Amount.ToString("C")</div></div>
        <div class="details-item"><div class="details-label">Açıklama</div><div class="details-value">@Model.WorkerPayment.Description</div></div>
    </div>
</div>

