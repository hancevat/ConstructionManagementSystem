@page
@model ConstructionManagementSystem.Pages.WorkerPayments.IndexModel
@{
    ViewData["Title"] = "İşçi Ödemeleri";
    var canManage = BuildTaskFlowPermissions.CanManageFinancialRecords(User);
}

<div class="page-heading">
    <div>
        <h1 class="h3 mb-1">İşçi Ödemeleri</h1>
        <p class="text-muted mb-0">Projelere bağlı işçi ödeme kayıtları.</p>
    </div>
    @if (canManage)
    {
        <a class="btn btn-primary" asp-page="Create">Yeni İşçi Ödemesi</a>
    }
</div>

<div class="content-card p-3">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>Tarih</th>
                    <th>İşçi</th>
                    <th>Proje</th>
                    <th>Gün</th>
                    <th>Tutar</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.WorkerPayments)
                {
                    <tr>
                        <td>@item.PaymentDate.ToString("dd.MM.yyyy")</td>
                        <td>@item.Worker?.FullName</td>
                        <td>@item.ConstructionProject?.Name</td>
                        <td>@item.WorkDays</td>
                        <td>@item.Amount.ToString("C")</td>
                        <td>
                            <div class="actions">
                                <a class="btn btn-outline-info btn-sm" asp-page="Details" asp-route-id="@item.Id">Detay</a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

